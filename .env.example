# Path to the Google OAuth client credentials JSON (download from Google Cloud Console).
# See README "Google Drive setup" for instructions.
SIBPARSER_GOOGLE_CREDENTIALS=./credentials.json

# Path where the Drive OAuth token will be cached after the first login.
SIBPARSER_GOOGLE_TOKEN=./token.json

# Drive folder name that the parser will create / use as the root.
# All categories will be created as subfolders under it.
SIBPARSER_DRIVE_ROOT_FOLDER=SiberianHealthParser

# Local staging directory (temporary copies of downloaded files before upload).
SIBPARSER_DOWNLOADS_DIR=./downloads

# SQLite state file for resumable runs and certificate dedup.
SIBPARSER_STATE_DB=./state.db

# Show the Playwright browser window while scraping (true) or run headless (false).
SIBPARSER_HEADFUL=true

# How long to wait between requests, in seconds.
SIBPARSER_REQUEST_DELAY=0.5

# Where to bind the local UI server.
SIBPARSER_HOST=127.0.0.1
SIBPARSER_PORT=8765
